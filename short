variables:
  ACCELQ_API_KEY: ""
  ACCELQ_USER: ""
  ACCEL_DOMAIN: "navigate.accelq.io"
  ACCEL_TENANT: "123"
  JIRA_DOMAIN: "jira.yourcompany.com"
  JIRA_PAT: ""
  ACCELQ_RUN_ID: ""

stages:
  - sync_results

sync_to_xray:
  stage: sync_results
  before_script:
    - yum install -y curl jq || true
  script:
    - echo "Fetching ACCELQ Run Data for ID $ACCELQ_RUN_ID"
    - RUN_DATA=$(curl -s -k -X GET "https://$ACCEL_DOMAIN/api/1.0/$ACCEL_TENANT/runs/$ACCELQ_RUN_ID" -H "api_key:$ACCELQ_API_KEY" -H "user_id:$ACCELQ_USER")
    - RUN_NAME=$(echo "$RUN_DATA" | jq -r '.runName')
    - if [[ "$RUN_NAME" =~ [Mm]obile ]]; then TARGET="Mobile"; else TARGET="Browser"; fi
    - echo "Target Filter set to $TARGET"
    - |
      echo "$RUN_DATA" | jq -c '.testCases[]' | while read -r scenario; do
        SCENARIO_NAME=$(echo "$scenario" | jq -r '.scenarioName')
        STATUS=$(echo "$scenario" | jq -r '.testStatus')
        XRAY_STATUS="FAIL"; [ "$STATUS" == "PASS" ] && XRAY_STATUS="PASS"
        ALL_KEYS=$(echo "$scenario" | jq -r '.jiraIssues[]')
        EXECUTION_KEY=""
        TEST_KEYS_JSON=""
        for KEY in $ALL_KEYS; do
          JIRA_DATA=$(curl -s -k -H "Authorization: Bearer $JIRA_PAT" -X GET "https://$JIRA_DOMAIN/rest/api/2/issue/$KEY?fields=issuetype,summary")
          TYPE=$(echo "$JIRA_DATA" | jq -r '.fields.issuetype.name')
          SUMMARY=$(echo "$JIRA_DATA" | jq -r '.fields.summary')
          if [[ "$TYPE" == "Test Execution" && "$SUMMARY" =~ $TARGET ]]; then EXECUTION_KEY=$KEY; fi
          if [[ "$TYPE" == "Test" ]]; then TEST_KEYS_JSON="${TEST_KEYS_JSON}{\"testKey\":\"$KEY\",\"status\":\"$XRAY_STATUS\"},"; fi
        done
        if [[ -n "$EXECUTION_KEY" && -n "$TEST_KEYS_JSON" ]]; then
          TEST_KEYS_JSON=$(echo "$TEST_KEYS_JSON" | sed 's/,$//')
          PAYLOAD="{\"testExecutionKey\":\"$EXECUTION_KEY\",\"tests\":[$TEST_KEYS_JSON]}"
          curl -s -k -H "Authorization: Bearer $JIRA_PAT" -H "Content-Type: application/json" -X POST -d "$PAYLOAD" "https://$JIRA_DOMAIN/rest/xray/2.0/api/import/execution"
          echo "Updated $EXECUTION_KEY for scenario $SCENARIO_NAME"
        fi
      done
